colors=(5 4 6 2 3 1 7)  # зґ«гЂЃиѓіѓЅгЂЃйѓЅѓІгЂЃз»їгЂЃй»ѓ¤гЂЃзєѓ‚гЂЃзѓ№Ѕ\
bold="on"\
separator=":"\
\
# жѓёѕз¤єдїѓЃжЃЇ\
print_info() {\
    info title\
    info underline\
    info "OS" distro\
    info "Host" model\
    info "Kernel" kernel\
    info "Uptime" uptime\
    info "Packages" packages\
    info "Shell" shell\
    info "Terminal" term\
    info "CPU" cpu\
    info "GPU" gpu\
    info "Memory" memory\
}\
\
# йѓєѓ°иѓ·ѓЇй»ѓёи®¤зѓєѓ¤ logo иѓЃѓ¬\
logo="on"\
ascii_colors=(5 4 6 2 3 1 7)\
\
# иѕ№жѓЃѓ¦жѓЂ·ејѓЇ\
underline_char="-"\
underline_enabled="on"\
\
# еѓҐ¶д»ѓ¶и®ѕзЅ®\
kernel_shorthand="on"\
uptime_shorthand="on"\
memory_percent="on"\
