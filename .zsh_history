: 1775772952:0;" ==================== жѓµ°е­ѓ·еѓ‚ѓѕеѓ§ѓЇеѓ§Ѕжѓµ° ====================\
function! Incr()\
  let c = col(".")\
  let line = getline(".")\
  let before = strpart(line, 0, c-1)\
  let num_start = match(before, '\d\+$')\
  if num_start == -1\
    let num_start = c-1\
  else\
    let num_start = num_start + 1\
  endif\
  let num_match = matchstr(line, '\d\+', num_start)\
  if num_match == "" | return | endif\
  let num_len = len(num_match)\
  let num_val = str2nr(num_match)\
  let new_num = num_val + 1\
  let new_num_str = printf("%0" . num_len . "d", new_num)\
  let before_num = strpart(line, 0, num_start)\
  let after_num = strpart(line, num_start + num_len)\
  let new_line = before_num . new_num_str . after_num\
  call setline(".", new_line)\
  call cursor(line("."), num_start + len(new_num_str))\
endfunction\
\
function! Decr()\
  let c = col(".")\
  let line = getline(".")\
  let before = strpart(line, 0, c-1)\
  let num_start = match(before, '\d\+$')\
  if num_start == -1\
    let num_start = c-1\
  else\
    let num_start = num_start + 1\
  endif\
  let num_match = matchstr(line, '\d\+', num_start)\
  if num_match == "" | return | endif\
  let num_len = len(num_match)\
  let num_val = str2nr(num_match)\
  if num_val == 0 | return | endif\
  let new_num = num_val - 1\
  let new_num_str = printf("%0" . num_len . "d", new_num)\
  let before_num = strpart(line, 0, num_start)\
  let after_num = strpart(line, num_start + num_len)\
  let new_line = before_num . new_num_str . after_num\
  call setline(".", new_line)\
  call cursor(line("."), num_start + len(new_num_str))\
endfunction\
\
nnoremap <C-a> :call Incr()<CR>\
nnoremap <C-x> :call Decr()<CR>\
\
