: 1775259512:0;python3 << 'EOF'\
import sys\
\
# Catppuccin Mocha 14 иѓ©І\
colors = [\
    "#f5e0dc", "#f2cdcd", "#f5c2e7", "#cba6f7", "#f38ba8", "#eba0ac",\
    "#fab387", "#f9e2af", "#a6e3a1", "#94e2d5", "#89dceb", "#74c7ec",\
    "#89b4fa", "#b4befe"\
]\
\
# иЇ»еѓЇѓ¶жѓ¶ѓ§д»¶еѓ¦ѓҐе®№\
with open("catppuccin.txt", "r") as f:\
    text = f.read()\
\
# йЂѓ°е­ѓ·з¬¦зѓЅЂиѓ©І\
result = []\
color_idx = 0\
for char in text:\
    if char.strip():  # йѓЅѓѕз©єзѓ№Ѕе­ѓ·з¬¦\
        color = colors[color_idx % len(colors)]\
        r = int(color[1:3], 16)\
        g = int(color[3:5], 16)\
        b = int(color[5:7], 16)\
        result.append(f"\033[38;2;{r};{g};{b}m{char}\033[0m")\
        color_idx += 1\
    else:\
        result.append(char)\
\
print(''.join(result))\
EOF
: 1775259569:0;python3 << 'EOF'\
# Catppuccin Mocha 14 иѓ©І\
colors = [\
    "#f5e0dc", "#f2cdcd", "#f5c2e7", "#cba6f7", "#f38ba8", "#eba0ac",\
    "#fab387", "#f9e2af", "#a6e3a1", "#94e2d5", "#89dceb", "#74c7ec",\
    "#89b4fa", "#b4befe"\
]\
\
with open("catppuccin.txt", "r") as f:\
    lines = f.readlines()\
\
for i, line in enumerate(lines):\
    color = colors[i % len(colors)]\
    r = int(color[1:3], 16)\
    g = int(color[3:5], 16)\
    b = int(color[5:7], 16)\
    print(f"\033[38;2;{r};{g};{b}m{line.rstrip()}\033[0m")\
EOF
: 1775259611:0;python3 << 'EOF'\
# Catppuccin Mocha 14 иѓ©І\
colors = [\
    "#f5e0dc", "#f2cdcd", "#f5c2e7", "#cba6f7", "#f38ba8", "#eba0ac",\
    "#fab387", "#f9e2af", "#a6e3a1", "#94e2d5", "#89dceb", "#74c7ec",\
    "#89b4fa", "#b4befe"\
]\
\
with open("catppuccin.txt", "r") as f:\
    lines = [line.rstrip('\n') for line in f.readlines()]\
\
if not lines:\
    exit()\
\
max_len = max(len(line) for line in lines)\
\
# жѓ¬ѓ©еѓЁѓ·иѕѓіеѓ§є\
for col in range(max_len):\
    color = colors[col % len(colors)]\
    r = int(color[1:3], 16)\
    g = int(color[3:5], 16)\
    b = int(color[5:7], 16)\
    \
    for line in lines:\
        if col < len(line):\
            print(f"\033[38;2;{r};{g};{b}m{line[col]}\033[0m", end="")\
        else:\
            print(" ", end="")\
    print()  # жѓ­ѓ‚иѓЃѓ¬\
EOF
