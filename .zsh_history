: 1774872501:0;cat > ~/.config/mpv/mpv.conf << 'EOF'\
# ========== еѓїєзѓЃЂи®ѕзЅ® ==========\
# йѓїійѓ‚ѓ±иѕѓіеѓ§єпјѓЁTermux зѓґЁ openslesпјѓ©\
ao=opensles\
# жѓ·ѓЂи§ѓ¦йѓ‚ѓ±иѕѓіеѓ§єпјѓЁзєЇйѓїійѓ‚ѓ±жЁѓЃејѓЇпјѓ©\
vo=null\
\
# ========== зјѓіе­ѓёдјѓёеѓ¬ѓ¶ ==========\
cache=yes\
cache-secs=5\
demuxer-max-bytes=150M\
demuxer-max-back-bytes=50M\
\
# ========== зЅѓ±з»ѓјдјѓёеѓ¬ѓ¶ ==========\
network-timeout=60\
force-seekable=yes\
ytdl-format=bestaudio/best\
\
# ========== йѓїійѓ‚ѓ±дјѓёеѓ¬ѓ¶ =========#\
audio-device=auto\
audio-buffer=1\
audio-exclusive=no\
\
# ========== зѓµѓ¬йѓЅѓ‚ ==========\
# OSD йѓ‚ѓјиѓ©ІпјѓЁCatppuccin зґ«иѓ©Іпјѓ©\
osd-color="#cba6f7"\
osd-back-color="#1e1e2e"\
osd-font-size=30\
osd-duration=3000\
\
# иїѓ»еє¦жѓЅѓЃжѓёѕз¤є\
osd-level=2\
term-osd=yes\
term-osd-bar=yes\
\
# ========== жѓІ­жѓґѕеѓЁѓ·иѓЃЁ ==========\
playlist-pos=0\
loop-playlist=no\
shuffle=no\
\
# ========== еї«жѓ­·йѓґ®еѓ‚ѓѕејє ==========\
# йѓҐѓ­зЅ®жѓ¶ѓ§д»¶дЅѓ­зЅ®\
input-conf=~/.config/mpv/input.conf\
EOF
: 1774872514:0;cat > ~/.config/mpv/input.conf << 'EOF'\
# жѓІ­жѓґѕжѓ®§еѓЁ¶\
SPACE cycle pause\
q quit\
Q quit-watch-later\
\
# йѓїійѓ§ѓЇ\
UP add volume 5\
DOWN add volume -5\
m cycle mute\
\
# иїѓ»еє¦\
LEFT seek -5\
RIGHT seek 5\
Shift+LEFT seek -60\
Shift+RIGHT seek 60\
Ctrl+LEFT playlist-prev\
Ctrl+RIGHT playlist-next\
\
# йЂѓїеє¦\
[ multiply speed 0.9091\
] multiply speed 1.1\
{ set speed 0.5\
} set speed 2.0\
BACKSPACE set speed 1.0\
\
# дїѓЃжЃЇ\
i script-binding stats/display-stats\
I script-binding stats/display-stats-toggle\
\
# жѓІ­жѓґѕеѓЁѓ·иѓЃЁ\
ENTER script-binding playlist\
TAB script-binding playlist\
\
# жѓЁЄеѓ»ѕпјѓЁи§ѓ¦йѓ‚ѓ±пјѓ©\
s screenshot\
S screenshot video\
EOF
