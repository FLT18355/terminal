: 1774871391:0;cat > ~/.config/tmux/tmux.conf << 'EOF'\
# ========== еѓїєзѓЃЂи®ѕзЅ® ==========\
set -g default-terminal "screen-256color"\
set -g mouse on\
set -g history-limit 10000\
set -g base-index 1\
set -g pane-base-index 1\
\
# ========== зѓЄ¶жЂЃжѓЂѓЇпјѓЁCatppuccin Mochaпјѓ©==========\
set -g status-style "bg=#1e1e2e,fg=#cdd6f4"\
set -g status-left "#[fg=#89b4fa,bold] #S #[default]"\
set -g status-right "#[fg=#cba6f7] %H:%M #[fg=#a6e3a1] %Y-%m-%d "\
\
# зЄѓ·еѓЇЈжѓЂ·ејѓЇ\
set -g window-status-format " #I: #W "\
set -g window-status-current-format "#[fg=#f38ba8,bold] #I: #W #[default]"\
\
# еѓЁѓ¦еѓ©Ізєї\
set -g pane-border-style "fg=#45475a"\
set -g pane-active-border-style "fg=#89b4fa"\
\
# ж¶ѓЁжЃЇжѓЂ·ејѓЇ\
set -g message-style "bg=#1e1e2e,fg=#89b4fa"\
\
# ========== еї«жѓ­·йѓґ® ==========\
# йѓ§ѓ­жѓ¶°еѓЄѓЂиЅЅйѓҐѓ­зЅ®\
bind r source-file ~/.config/tmux/tmux.conf \; display "йѓҐѓ­зЅ®е·Ійѓ§ѓ­иЅЅ"\
\
# еѓЁѓ¦е±ѓЇ\
bind | split-window -h\
bind - split-window -v\
\
# жѓ¶№еѓ°ѓ±йѓґ®еѓЁѓ§жѓ­ѓ‚еѓЁѓ¦е±ѓЇ\
bind h select-pane -L\
bind j select-pane -D\
bind k select-pane -U\
bind l select-pane -R\
\
# ========== жѓЇѓІд»¶еѓЁѓ·иѓЃЁ ==========\
set -g @plugin 'tmux-plugins/tpm'\
set -g @plugin 'tmux-plugins/tmux-resurrect'\
set -g @plugin 'tmux-plugins/tmux-continuum'\
set -g @plugin 'tmux-plugins/tmux-yank'\
\
# жѓЇѓІд»¶и®ѕзЅ®\
set -g @resurrect-capture-pane-contents 'on'\
set -g @continuum-restore 'on'\
\
# еѓЁѓЅе§ѓ«еѓ¬ѓ¶ TPMпјѓЁеїѓҐйѓЃ»жѓґѕеѓјЁжѓјЂеѓ°ѓ®пјѓ©\
run '~/.config/tmux/plugins/tpm/tpm'\
EOF
