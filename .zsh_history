" жѓ¬ѓ© F5 иїѓ°иѓЃѓ¬иѓ¤ѓєжѓј¬\
autocmd FileType python nnoremap <buffer> <F5> :w<bar>python3 << 'EOF'\
color = "#b4befe"\
r = int(color[1:3], 16)\
g = int(color[3:5], 16)\
b = int(color[5:7], 16)\
\
with open("catppuccin.txt", "r") as f:\
    for line in f:\
        print(f"\033[38;2;{r};{g};{b}m{line.rstrip()}\033[0m")\
EOF %<CR>\
autocmd FileType lua nnoremap <buffer> <F5> :w<bar>lua5.5 lua.lua %<CR>\
autocmd FileType sh nnoremap <buffer> <F5> :w<bar>!bash %<CR>\
autocmd FileType javascript nnoremap <buffer> <F5> :w<bar>node player.js  %<CR>\
autocmd FileType rust nnoremap <buffer> <F5> :w<bar>cargo run %<CR>
