    --underlineNav-borderColor-active: var(--accent);
    --underlineNav-borderColor-hover: #6e768166;
    --underlineNav-iconColor-rest: #848d97;
    --selection-bgColor: ${fade(accent, 30)};
    --reactionButton-selected-bgColor-rest: ${fade(accent, 20)};
    --reactionButton-selected-bgColor-hover: ${fade(accent, 35)};
    --reactionButton-selected-fgColor-rest: var(--accent);
    --reactionButton-selected-fgColor-hover: var(--accent);
    --fgColor-default: ${colors.text};
    --fgColor-muted: ${colors.subtext1};
    --fgColor-onEmphasis: ${colors.base};
    --fgColor-white: ${colors.text};
    --fgColor-disabled: ${colors.surface2};
    --fgColor-link: var(--accent);
    --fgColor-neutral: ${colors.subtext1};
    --fgColor-accent: var(--accent);
    --fgColor-success: ${colors.green};
    --fgColor-attention: ${colors.yellow};
    --fgColor-severe: ${colors.peach};
    --fgColor-danger: ${colors.red};
