// ==UserScript==
// @name         GitHub Catppuccin (Full)
// @namespace    https://github.com/catppuccin/userstyles
// @version      2026.02.17
// @description  Soothing pastel theme for GitHub - Complete
// @author       Catppuccin
// @license      MIT
// @match        *://github.com/*
// @match        *://gist.github.com/*
// @match        *://docs.github.com/*
// @match        *://viewscreen.githubusercontent.com/*
// @grant        GM_addStyle
// @run-at       document-start
// ==/UserScript==

(function() {
    'use strict';

    // ============================================================
    // Catppuccin Mocha 完整配色
    // ============================================================
    const colors = {
        rosewater: "#f5e0dc", flamingo:  "#f2cdcd",
        pink:      "#f5c2e7", mauve:     "#cba6f7",
        red:       "#f38ba8", maroon:    "#eba0ac",
        peach:     "#fab387", yellow:    "#f9e2af",
        green:     "#a6e3a1", teal:      "#94e2d5",
        blue:      "#89b4fa", sapphire:  "#74c7ec",
        sky:       "#89dceb", lavender:  "#b4befe",
        text:      "#cdd6f4", subtext1:  "#bac2de",
        subtext0:  "#a6adc8", overlay2:  "#9399b2",
        overlay1:  "#7f849c", overlay0:  "#6c7086",
        surface2:  "#585b70", surface1:  "#45475a",
        surface0:  "#313244", base:      "#1e1e2e",
        mantle:    "#181825", crust:     "#11111b"
    };
    const accent = colors.mauve;
    const flavor = "mocha";  // mocha

    // 辅助函数
    function fade(hex, percent) {
        const r = parseInt(hex.slice(1,3), 16);
        const g = parseInt(hex.slice(3,5), 16);
        const b = parseInt(hex.slice(5,7), 16);
        return `rgba(${r}, ${g}, ${b}, ${percent/100})`;
    }
    function lighten(hex, percent) {
        const r = Math.min(255, parseInt(hex.slice(1,3),16) + Math.round(2.55 * percent));
        const g = Math.min(255, parseInt(hex.slice(3,5),16) + Math.round(2.55 * percent));
        const b = Math.min(255, parseInt(hex.slice(5,7),16) + Math.round(2.55 * percent));
        return `#${((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1)}`;
    }
    function darken(hex, percent) {
        const r = Math.max(0, parseInt(hex.slice(1,3),16) - Math.round(2.55 * percent));
        const g = Math.max(0, parseInt(hex.slice(3,5),16) - Math.round(2.55 * percent));
        const b = Math.max(0, parseInt(hex.slice(5,7),16) - Math.round(2.55 * percent));
        return `#${((1 << 24) + (r << 16) + (g << 8) + b).toString(16).slice(1)}`;
    }

    // ============================================================
    // 完整 CSS
    // ============================================================
    let css = `:root {
        --accent: ${accent};
        --rosewater: ${colors.rosewater};
        --flamingo: ${colors.flamingo};
        --pink: ${colors.pink};
        --mauve: ${colors.mauve};
        --red: ${colors.red};
        --maroon: ${colors.maroon};
        --peach: ${colors.peach};
        --yellow: ${colors.yellow};
        --green: ${colors.green};
        --teal: ${colors.teal};
        --blue: ${colors.blue};
        --sapphire: ${colors.sapphire};
        --sky: ${colors.sky};
        --lavender: ${colors.lavender};
        --text: ${colors.text};
        --subtext1: ${colors.subtext1};
        --subtext0: ${colors.subtext0};
        --overlay2: ${colors.overlay2};
        --overlay1: ${colors.overlay1};
        --overlay0: ${colors.overlay0};
        --surface2: ${colors.surface2};
        --surface1: ${colors.surface1};
        --surface0: ${colors.surface0};
        --base: ${colors.base};
        --mantle: ${colors.mantle};
        --crust: ${colors.crust};
    }
    body, html { color: ${colors.text}; background-color: ${colors.base}; }
    accent-color: var(--accent);
    color: ${colors.text};
    .cm-placeholder { color: ${colors.subtext0}; }
    --color-social-reaction-bg-reacted-hover: ${fade(accent, 30)};
    --color-notifications-button-hover-bg: ${fade(accent, 60)};
    --color-workflow-card-header-shadow: rgba(27,31,35,0.04);
    --color-icon-directory: var(--fgColor-muted, var(--color-fg-muted));
    --color-calendar-halloween-graph-day-L1-bg: ${fade(accent, 40)} !important;
    --color-calendar-halloween-graph-day-L2-bg: ${fade(accent, 60)} !important;
    --color-calendar-halloween-graph-day-L3-bg: ${fade(accent, 80)} !important;
    --color-calendar-halloween-graph-day-L4-bg: var(--accent) !important;
    --color-calendar-winter-graph-day-L1-bg: ${fade(accent, 40)} !important;
    --color-calendar-winter-graph-day-L2-bg: ${fade(accent, 60)} !important;
    --color-calendar-winter-graph-day-L3-bg: ${fade(accent, 80)} !important;
    --color-calendar-winter-graph-day-L4-bg: var(--accent) !important;
    --color-calendar-graph-day-bg: ${colors.surface0} !important;
    --color-calendar-graph-day-border: transparent !important;
    --color-calendar-graph-day-L1-bg: ${fade(accent, 40)} !important;
    --color-calendar-graph-day-L2-bg: ${fade(accent, 60)} !important;
    --color-calendar-graph-day-L3-bg: ${fade(accent, 80)} !important;
    --color-calendar-graph-day-L4-bg: var(--accent) !important;
    --color-calendar-graph-day-L2-border: transparent !important;
    --color-calendar-graph-day-L3-border: transparent !important;
    --color-calendar-graph-day-L4-border: transparent !important;
    --contribution-default-bgColor-0: ${fade(accent, 10)} !important;
    --contribution-default-bgColor-1: ${fade(accent, 40)} !important;
    --contribution-default-bgColor-2: ${fade(accent, 60)} !important;
    --contribution-default-bgColor-3: ${fade(accent, 80)} !important;
    --contribution-default-bgColor-4: var(--accent) !important;
    --color-user-mention-fg: var(--accent);
    --color-user-mention-bg: ${fade(accent, 30)};
    --color-dashboard-feed-bg: var(--color-scale-gray-9);
    --color-mktg-btn-shadow-outline: rgba(255,255,255,0.25) 0 0 0 1px inset;
    --color-marketing-icon-secondary: var(--color-scale-blue-5);
    --color-project-header-bg: var(--color-scale-gray-9);
    --color-project-sidebar-bg: var(--color-scale-gray-8);
    --color-project-gradient-in: var(--color-scale-gray-8);
    --color-project-gradient-out: rgba(22,27,34,0);
    --color-diff-blob-selected-line-highlight-mix-blend-mode: screen;
    --topicTag-borderColor: #0000;
    --highlight-neutral-bgColor: ${fade(colors.yellow, 30)};
    --page-header-bgColor: ${colors.crust};
    --diffBlob-additionNum-bgColor: ${fade(colors.green, 30)};
    --diffBlob-additionNum-fgColor: ${colors.text};
    --diffBlob-additionLine-bgColor: ${fade(colors.green, 15)};
    --diffBlob-additionWord-bgColor: ${fade(colors.green, 30)};
    --diffBlob-additionWord-fgColor: ${colors.text};
    --diffBlob-deletionNum-bgColor: ${fade(colors.red, 30)};
    --diffBlob-deletionNum-fgColor: ${colors.text};
    --diffBlob-deletionLine-bgColor: ${fade(colors.red, 15)};
    --diffBlob-deletionWord-bgColor: ${fade(colors.red, 30)};
    --diffBlob-deletionWord-fgColor: ${colors.text};
    --diffBlob-hunkNum-bgColor-rest: ${fade(accent, 40)};
    --diffBlob-hunkNum-bgColor-hover: ${fade(accent, 75)};
    --diffBlob-hunkLine-bgColor: ${fade(accent, 25)};
    --diffBlob-expander-iconColor: ${colors.subtext0};
    --diffBlob-emptyNum-bgColor: ${colors.mantle};
    --diffBlob-emptyLine-bgColor: ${colors.mantle};
    --codeMirror-fgColor: ${colors.text};
    --codeMirror-bgColor: ${colors.base};
    --codeMirror-gutters-bgColor: ${colors.base};
    --codeMirror-gutterMarker-fgColor-default: ${colors.base};
    --codeMirror-gutterMarker-fgColor-muted: ${colors.overlay0};
    --codeMirror-lineNumber-fgColor: ${colors.overlay1};
    --codeMirror-cursor-fgColor: ${colors.text};
    --codeMirror-selection-bgColor: #388bfd66;
    --codeMirror-activeline-bgColor: #6e768166;
    --codeMirror-matchingBracket-fgColor: ${colors.text};
    --codeMirror-lines-bgColor: ${colors.base};
    --codeMirror-syntax-fgColor-comment: ${colors.overlay2};
    --codeMirror-syntax-fgColor-constant: ${colors.blue};
    --codeMirror-syntax-fgColor-entity: ${colors.blue};
    --codeMirror-syntax-fgColor-keyword: ${colors.mauve};
    --codeMirror-syntax-fgColor-storage: ${colors.peach};
    --codeMirror-syntax-fgColor-string: ${colors.green};
    --codeMirror-syntax-fgColor-support: #79c0ff;
    --codeMirror-syntax-fgColor-variable: ${colors.peach};
    --header-fgColor-default: ${colors.text};
    --header-fgColor-logo: ${colors.text};
    --header-bgColor: ${colors.crust};
    --header-borderColor-divider: #8b949e;
    --headerSearch-bgColor: ${colors.mantle};
    --headerSearch-borderColor: ${colors.surface0};
    --avatar-bgColor: ${fade(colors.text, 26)};
    --avatar-borderColor: ${colors.surface0};
    --avatar-shadow: 0px 0px 0px 2px #0d1117;
    --avatarStack-fade-bgColor-default: ${colors.surface1};
    --avatarStack-fade-bgColor-muted: #21262d;
    --control-bgColor-rest: ${colors.red};
    --control-bgColor-hover: #292e36;
    --control-bgColor-active: ${colors.surface1};
    --control-bgColor-disabled: ${fade(colors.mantle, 60)};
    --control-bgColor-selected: #161b22;
    --control-fgColor-rest: ${colors.text};
    --control-fgColor-placeholder: #484f58;
    --control-fgColor-disabled: ${fade(colors.subtext0, 70)};
    --control-borderColor-rest: ${colors.surface1};
    --control-borderColor-emphasis: #666e79;
    --control-borderColor-disabled: ${fade(colors.surface1, 75)};
    --control-borderColor-selected: #f0f6fc;
    --control-borderColor-success: ${colors.green};
    --control-borderColor-danger: ${colors.red};
    --control-borderColor-warning: ${colors.yellow};
    --control-iconColor-rest: #848d97;
    --control-transparent-bgColor-rest: #0000;
    --control-transparent-bgColor-hover: ${fade(colors.surface2, 20)};
    --control-transparent-bgColor-active: ${fade(colors.overlay0, 50)};
    --control-transparent-bgColor-disabled: #21262db3;
    --control-transparent-bgColor-selected: #b1bac414;
    --control-transparent-borderColor-rest: #0000;
    --control-transparent-borderColor-hover: #0000;
    --control-transparent-borderColor-active: #0000;
    --control-danger-fgColor-rest: ${colors.red};
    --control-danger-fgColor-hover: ${colors.crust};
    --control-danger-bgColor-hover: ${fade(colors.red, 80)};
    --control-danger-bgColor-active: ${colors.red};
    --control-checked-bgColor-rest: var(--accent);
    --control-checked-bgColor-hover: ${lighten(accent, 5)};
    --control-checked-bgColor-active: ${lighten(accent, 5)};
    --control-checked-bgColor-disabled: #6e7681;
    --control-checked-fgColor-rest: ${colors.crust};
    --control-checked-fgColor-disabled: #010409;
    --control-checked-borderColor-rest: var(--accent);
    --control-checked-borderColor-hover: var(--accent);
    --control-checked-borderColor-active: var(--accent);
    --control-checked-borderColor-disabled: ${colors.surface0};
    --controlTrack-bgColor-rest: ${colors.surface0};
    --controlTrack-bgColor-hover: ${colors.surface1};
    --controlTrack-bgColor-active: ${colors.surface2};
    --controlTrack-bgColor-disabled: #6e7681;
    --controlTrack-fgColor-rest: #848d97;
    --controlTrack-fgColor-disabled: ${colors.text};
    --controlTrack-borderColor-rest: #0000;
    --controlTrack-borderColor-disabled: #6e7681;
    --controlKnob-bgColor-rest: ${colors.base};
    --controlKnob-bgColor-disabled: #21262db3;
    --controlKnob-bgColor-checked: ${colors.text};
    --controlKnob-borderColor-rest: ${colors.surface2};
    --controlKnob-borderColor-disabled: #21262db3;
    --controlKnob-borderColor-checked: ${colors.blue};
    --button-default-fgColor-rest: ${colors.text};
    --button-default-bgColor-rest: ${colors.surface0};
    --button-default-bgColor-hover: ${colors.surface1};
    --button-default-bgColor-active: ${colors.surface2};
    --button-default-bgColor-selected: ${colors.surface2};
    --button-default-bgColor-disabled: ${fade(colors.surface0, 70)};
    --button-default-borderColor-rest: ${colors.surface1};
    --button-default-borderColor-hover: ${colors.surface1};
    --button-default-borderColor-active: ${colors.surface1};
    --button-default-borderColor-disabled: ${fade(colors.surface0, 70)};
    --button-default-shadow-resting: 0px 0px 0px 0px #000;
    --button-primary-fgColor-rest: ${colors.base};
    --button-primary-fgColor-disabled: ${fade(colors.base, 60)};
    --button-primary-iconColor-rest: ${colors.base};
    --button-primary-bgColor-rest: ${colors.green};
    --button-primary-bgColor-hover: ${lighten(colors.green, 5)};
    --button-primary-bgColor-active: ${darken(colors.green, 5)};
    --button-primary-bgColor-disabled: ${fade(colors.green, 70)};
    --button-primary-borderColor-rest: ${colors.green};
    --button-primary-borderColor-hover: ${colors.green};
    --button-primary-borderColor-active: ${colors.green};
    --button-primary-borderColor-disabled: ${fade(colors.green, 70)};
    --button-primary-shadow-selected: 0px 0px 0px 0px #000;
    --button-invisible-fgColor-rest: ${colors.text};
    --button-invisible-fgColor-hover: ${lighten(accent, 10)};
    --button-invisible-fgColor-disabled: #6e7681;
    --button-invisible-iconColor-rest: ${colors.overlay2};
    --button-invisible-iconColor-hover: #e6edf3;
    --button-invisible-iconColor-disabled: #6e7681;
    --button-invisible-bgColor-rest: #0000;
    --button-invisible-bgColor-hover: #b1bac41f;
    --button-invisible-bgColor-active: #b1bac433;
    --button-invisible-bgColor-disabled: ${fade(colors.surface1, 70)};
    --button-invisible-borderColor-rest: #0000;
    --button-invisible-borderColor-hover: #0000;
    --button-invisible-borderColor-disabled: ${fade(colors.surface1, 70)};
    --button-outline-fgColor-rest: #388bfd;
    --button-outline-fgColor-hover: #58a6ff;
    --button-outline-fgColor-active: ${colors.text};
    --button-outline-fgColor-disabled: #4493f880;
    --button-outline-bgColor-rest: #f0f6fc;
    --button-outline-bgColor-hover: ${colors.surface1};
    --button-outline-bgColor-active: #0d419d;
    --button-outline-bgColor-disabled: #0d1117;
    --button-outline-borderColor-hover: #f0f6fc1a;
    --button-outline-borderColor-selected: #f0f6fc1a;
    --button-outline-shadow-selected: 0px 0px 0px 0px #000;
    --button-danger-fgColor-rest: ${colors.red};
    --button-danger-fgColor-hover: ${colors.base};
    --button-danger-fgColor-active: ${colors.base};
    --button-danger-fgColor-disabled: ${fade(colors.red, 50)};
    --button-danger-iconColor-rest: ${colors.red};
    --button-danger-iconColor-hover: ${colors.crust};
    --button-danger-bgColor-rest: ${colors.surface0};
    --button-danger-bgColor-hover: ${colors.red};
    --button-danger-bgColor-active: ${darken(colors.red, 5)};
    --button-danger-bgColor-disabled: ${colors.base};
    --button-danger-borderColor-rest: ${colors.surface1};
    --button-danger-borderColor-hover: ${colors.red};
    --button-danger-borderColor-active: ${darken(colors.red, 5)};
    --button-danger-shadow-selected: 0px 0px 0px 0px #000;
    --button-inactive-fgColor: #8b949e;
    --button-inactive-bgColor: #21262d;
    --button-star-iconColor: ${colors.yellow};
    --buttonCounter-default-bgColor-rest: ${colors.surface1};
    --buttonCounter-invisible-bgColor-rest: ${colors.surface1};
    --buttonCounter-primary-bgColor-rest: #04260f33;
    --buttonCounter-outline-bgColor-rest: #051d4d33;
    --buttonCounter-outline-bgColor-hover: #051d4d33;
    --buttonCounter-outline-bgColor-disabled: #1f6feb0d;
    --buttonCounter-outline-fgColor-rest: #388bfd;
    --buttonCounter-outline-fgColor-hover: #58a6ff;
    --buttonCounter-outline-fgColor-disabled: #4493f880;
    --buttonCounter-danger-bgColor-hover: ${fade(colors.text, 20)};
    --buttonCounter-danger-bgColor-disabled: #da36330d;
    --buttonCounter-danger-bgColor-rest: #49020233;
    --buttonCounter-danger-fgColor-rest: ${colors.red};
    --buttonCounter-danger-fgColor-hover: ${colors.text};
    --buttonCounter-danger-fgColor-disabled: ${fade(colors.red, 50)};
    --focus-outlineColor: var(--accent);
    --menu-bgColor-active: ${colors.mantle};
    --overlay-bgColor: ${colors.base};
    --overlay-borderColor: ${colors.surface0};
    --overlay-backdrop-bgColor: #161b2266;
    --selectMenu-borderColor: #484f58;
    --selectMenu-bgColor-active: #0c2d6b;
    --sideNav-bgColor-selected: #21262d;
    --skeletonLoader-bgColor: #161b22;
    --timelineBadge-bgColor: ${colors.mantle};
