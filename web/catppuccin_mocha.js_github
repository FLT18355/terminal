    --fgColor-closed: ${colors.red};
    --fgColor-done: ${colors.mauve};
    --fgColor-sponsors: ${colors.pink};
    --bgColor-default: ${colors.base};
    --bgColor-muted: ${colors.mantle};
    --bgColor-inset: ${colors.crust};
    --bgColor-emphasis: ${colors.overlay2};
    --bgColor-inverse: ${colors.text};
    --bgColor-disabled: #21262db3;
    --bgColor-transparent: #0000;
    --bgColor-neutral-muted: ${fade(colors.surface0, 40)};
    --bgColor-neutral-emphasis: ${colors.subtext0};
    --bgColor-accent-muted: ${fade(accent, 20)};
    --bgColor-accent-emphasis: var(--accent);
    --bgColor-success-muted: #2ea04326;
    --bgColor-success-emphasis: ${colors.green};
    --bgColor-attention-muted: ${fade(colors.yellow, 15)};
    --bgColor-attention-emphasis: ${colors.yellow};
    --bgColor-severe-muted: ${fade(colors.peach, 26)};
    --bgColor-severe-emphasis: ${colors.peach};
    --bgColor-danger-muted: ${fade(colors.red, 26)};
    --bgColor-danger-emphasis: ${colors.red};
    --bgColor-open-muted: #2ea0431a;
    --bgColor-open-emphasis: ${colors.green};
    --bgColor-closed-muted: ${fade(colors.red, 15)};
    --bgColor-closed-emphasis: ${colors.red};
    --bgColor-done-muted: #a371f726;
    --bgColor-done-emphasis: ${colors.mauve};
    --bgColor-sponsors-muted: #db61a21a;
    --bgColor-sponsors-emphasis: ${colors.pink};
    --borderColor-default: ${colors.surface1};
    --borderColor-muted: ${colors.surface0};
    --borderColor-emphasis: #484f58;
    --borderColor-disabled: #21262db3;
    --borderColor-transparent: #0000;
    --borderColor-neutral-muted: #6e768166;
    --borderColor-neutral-emphasis: #6e7681;
    --borderColor-accent-muted: ${fade(accent, 50)};
    --borderColor-accent-emphasis: var(--accent);
    --borderColor-success-muted: ${darken(colors.green, 5)};
    --borderColor-success-emphasis: ${colors.green};
    --borderColor-attention-muted: ${fade(colors.flamingo, 30)};
    --borderColor-attention-emphasis: ${colors.flamingo};
    --borderColor-severe-muted: ${colors.peach};
    --borderColor-severe-emphasis: #bd561d;
    --borderColor-danger-muted: ${colors.red};
    --borderColor-danger-emphasis: ${colors.red};
    --borderColor-open-muted: ${darken(colors.green, 5)};
    --borderColor-open-emphasis: ${colors.green};
    --borderColor-closed-muted: ${colors.red};
    --borderColor-closed-emphasis: ${colors.red};
    --borderColor-done-muted: ${colors.lavender};
    --borderColor-done-emphasis: ${colors.mauve};
    --borderColor-sponsors-muted: #db61a266;
    --borderColor-sponsors-emphasis: ${colors.pink};
`;

    // 颜色系统
    if (flavor !== 'latte') {
        css += `
    --color-ansi-black: ${colors.surface1};
    --color-ansi-black-bright: ${colors.surface2};
    --color-ansi-gray: ${colors.surface2};
    --color-ansi-white: ${colors.subtext1};
    --color-ansi-white-bright: ${colors.subtext0};
`;
    } else {
        css += `
    --color-ansi-black: ${colors.subtext1};
    --color-ansi-black-bright: ${colors.subtext0};
    --color-ansi-gray: ${colors.subtext0};
    --color-ansi-white: ${colors.surface2};
    --color-ansi-white-bright: ${colors.surface1};
`;
    }
    css += `
    --color-ansi-red: ${colors.red};
    --color-ansi-red-bright: ${colors.red};
    --color-ansi-green: ${colors.green};
    --color-ansi-green-bright: ${colors.green};
    --color-ansi-yellow: ${colors.yellow};
    --color-ansi-yellow-bright: ${colors.yellow};
    --color-ansi-blue: ${colors.blue};
    --color-ansi-blue-bright: ${colors.blue};
    --color-ansi-magenta: ${colors.pink};
    --color-ansi-magenta-bright: ${colors.pink};
    --color-ansi-cyan: ${colors.teal};
    --color-ansi-cyan-bright: ${colors.teal};
    --color-prettylights-syntax-comment: ${colors.overlay2};
    --color-prettylights-syntax-constant: ${colors.blue};
    --color-prettylights-syntax-constant-other-reference-link: ${colors.blue};
    --color-prettylights-syntax-entity: ${colors.blue};
    --color-prettylights-syntax-storage-modifier-import: ${colors.peach};
    --color-prettylights-syntax-entity-tag: ${colors.blue};
    --color-prettylights-syntax-keyword: ${colors.mauve};
    --color-prettylights-syntax-string: ${colors.green};
    --color-prettylights-syntax-variable: ${colors.peach};
    --color-prettylights-syntax-invalid-illegal-text: ${colors.red};
    --color-prettylights-syntax-invalid-illegal-bg: ${fade(colors.red, 15)};
    --color-prettylights-syntax-markup-heading: ${colors.red};
    --color-prettylights-syntax-markup-italic: ${colors.yellow};
    --color-prettylights-syntax-markup-bold: ${colors.yellow};
    --color-prettylights-syntax-markup-deleted-text: ${colors.text};
    --color-prettylights-syntax-markup-deleted-bg: ${fade(colors.red, 40)};
    --color-prettylights-syntax-markup-inserted-text: ${colors.text};
    --color-prettylights-syntax-markup-inserted-bg: ${fade(colors.green, 40)};
    --color-prettylights-syntax-markup-changed-text: ${colors.text};
    --color-prettylights-syntax-markup-changed-bg: ${fade(colors.yellow, 40)};
    --color-prettylights-syntax-markup-ignored-text: ${colors.text};
    --bgColor-white: ${colors.base};
    --color-scale-white: ${colors.base};
    --color-scale-gray-3: ${colors.overlay2};
    --color-scale-gray-5: ${colors.overlay0};
    --color-scale-gray-6: ${colors.surface1};
    --color-scale-gray-7: ${colors.surface1};
    --color-scale-blue-2: ${colors.sky};
    --color-scale-blue-5: ${colors.blue};
    --color-scale-green-3: ${colors.green};
    --color-scale-green-4: ${colors.green};
    --color-scale-yellow-3: ${colors.peach};
    --color-scale-orange-4: ${colors.peach};
    --color-scale-red-4: ${colors.red};
    --shadow-inset: inset 0px 1px 0px 0px ${colors.crust};
    --shadow-resting-xsmall: 0px 1px 0px 0px ${colors.crust};
    --shadow-resting-small: 0px 1px 0px 0px ${colors.crust}, 0px 1px 3px 0px ${colors.crust};
    --shadow-resting-medium: 0px 3px 6px 0px ${colors.crust};
    --shadow-floating-small: 0px 0px 0px 1px ${colors.base}, 0px 6px 12px -3px ${colors.crust}, 0px 6px 18px 0px ${colors.crust};
    --shadow-floating-medium: 0px 0px 0px 1px ${colors.surface0}, 0px 8px 16px -4px ${colors.crust}, 0px 4px 32px -4px ${colors.crust}, 0px 24px 48px -12px ${colors.crust}, 0px 48px 96px -24px ${colors.crust};
    --shadow-floating-large: 0px 0px 0px 1px ${colors.surface0}, 0px 24px 48px 0px #010409;
    --shadow-floating-xlarge: 0px 0px 0px 1px ${colors.surface0}, 0px 32px 64px 0px #010409;
    --shadow-floating-legacy: 0px 6px 12px -3px ${colors.crust}, 0px 6px 18px 0px ${colors.crust};
    --outline-focus: ${colors.blue} solid 2px;
`;
// ============================================================
    // 元素选择器样式
    // ============================================================
    css += `
    /* Feed Links */
    .feed-item-content a code, .feed-item-content a tt {
        color: var(--accent);
    }

    /* Customer Terms & Agreements Page */
    .enterprise-customer-agreement {
        color: ${colors.text} !important;
    }
    .enterprise-customer-agreement:hover .octicon,
    .enterprise-customer-agreement:hover h3 {
        color: var(--accent) !important;
    }

    /* Enhanced Repo Insights Views */
    --data-blue-color-emphasis: var(--accent);
    --data-red-color-emphasis: ${colors.red};
    --data-green-color-emphasis: ${colors.green};

    /* Copilot Chat */
    --display-green-fgColor: ${colors.green};
    --display-teal-fgColor: ${colors.teal};
    --display-purple-fgColor: ${colors.mauve};
    --display-blue-fgColor: ${colors.blue};
    --display-pink-fgColor: ${colors.pink};
    --display-gray-fgColor: ${colors.subtext0};
    react-app[app-name="copilot-immersive-v1"] button,
    copilot-dashboard-entrypoint button {
        color: ${colors.text};
    }

    /* docs.github.com */
    --color-fg-default: ${colors.text};
    --color-canvas-default: ${colors.base};
    --color-canvas-subtle: ${colors.mantle};

    --tooltip-fgColor: ${colors.base};
    --tooltip-bgColor: ${colors.overlay2};

    /* Refined GitHub */
    --rgh-heat-color: ${colors.peach};

    .turbo-progress-bar {
        background-color: var(--accent);
    }

    .form-select {
        background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='${encodeURIComponent(colors.subtext0)}' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='m4.427 9.427 3.396 3.396a.25.25 0 0 0 .354 0l3.396-3.396A.25.25 0 0 0 11.396 9H4.604a.25.25 0 0 0-.177.427M4.423 6.47 7.82 3.072a.25.25 0 0 1 .354 0L11.57 6.47a.25.25 0 0 1-.177.427H4.6a.25.25 0 0 1-.177-.427'/%3E%3C/svg%3E");
    }

    img[src="https://github.githubassets.com/assets/mona-loading-default-c3c7aad1282f.gif"] {
        content: url("https://giscus.catppuccin.com/assets/loading_48x48.gif");
    }

    /* Header when logged out */
    .header-search-button svg {
        fill: ${colors.text} !important;
    }
    .HeaderMenu-toggle-bar {
        border-color: ${colors.text};
    }
    .notification-indicator .mail-status {
        background-image: linear-gradient(var(--accent), ${darken(accent, 5)});
    }

    .CheckStep .ansifg-r { color: var(--color-ansi-red); }
    .CheckStep .ansifg-y { color: var(--color-ansi-yellow); }
    .CheckStep .ansifg-g { color: var(--color-ansi-green); }
    .CheckStep .ansifg-b { color: var(--color-ansi-blue); }
    .CheckStep .ansifg-c { color: var(--color-ansi-cyan); }
    .CheckStep .ansifg-m { color: var(--color-ansi-magenta); }
    .CheckStep .ansifg-gr { color: var(--color-ansi-gray); }

    .js-activity-overview-graph .js-highlight-blob {
        fill: var(--accent);
        stroke: var(--accent);
    }

    .subnav-link.selected {
        border-bottom-color: var(--accent);
    }

    /* Pull request check in progress indicator */
    [stroke="#DBAB0A"] {
        stroke: ${fade(colors.yellow, 70)} !important;
    }
    [fill="#DBAB0A"] {
        fill: ${colors.yellow} !important;
    }

    /* Issue timeline icon */
    .TimelineItem-Badge[class*="prc-Timeline-TimelineBadge"],
    .TimelineItem-Badge {
        fill: ${colors.base};
    }
`;

    // ============================================================
    // viewscreen Mermaid 图表样式
    // ============================================================
    css += `
    [data-color-mode="auto"][data-light-theme="light"],
    [data-color-mode="light"][data-light-theme="light"] {
        --color-btn-text: ${colors.text};
        --color-btn-bg: ${colors.surface0};
        --color-btn-border: ${colors.surface1};
        --color-btn-hover-bg: ${colors.surface1};
        --color-btn-hover-border: ${colors.surface2};
        --color-btn-active-bg: ${colors.surface2};
        --color-btn-selected-bg: ${colors.surface2};
        --color-btn-counter-bg: ${colors.surface2};
        --color-btn-outline-text: var(--accent);
        --color-fg-muted: ${colors.subtext1};
        --button-default-fgColor-rest: ${colors.text};
        --button-default-bgColor-rest: ${colors.surface0};
        --button-default-bgColor-hover: ${colors.surface1};
        --button-default-bgColor-active: ${colors.surface2};
        --button-default-bgColor-selected: ${colors.surface2};
        --button-default-bgColor-disabled: ${fade(colors.surface0, 70)};
        --button-default-borderColor-rest: ${colors.surface1};
        --button-default-borderColor-hover: ${colors.surface1};
        --button-default-borderColor-active: ${colors.surface1};
        --button-default-borderColor-disabled: ${fade(colors.surface0, 70)};
    }
    #diagram .node rect, #diagram .node circle, #diagram .node ellipse,
    #diagram .node polygon, #diagram .node path {
        fill: ${fade(accent, 10)};
        stroke: var(--accent);
    }
    #diagram .cluster rect {
        fill: ${colors.surface0};
        stroke: ${colors.surface2};
    }
    #diagram .label text, #diagram span, #diagram p {
        fill: ${colors.text};
        color: ${colors.text};
    }
    #diagram .flowchart-link {
        stroke: ${colors.subtext0};
    }
    #diagram .marker {
        stroke: ${colors.subtext0};
        fill: ${colors.subtext0};
    }
    #diagram .edgeLabel {
        background-color: ${colors.crust};
    }
    #diagram .edgeLabel p {
        background-color: ${colors.surface2};
    }
    .octicon {
        fill: var(--color-fg-muted) !important;
    }
`;

    // ============================================================
    // notebooks (Jupyter) 主题
    // ============================================================
    css += `
    :root {
        --jp-border-color0: var(--color-scale-gray-7);
        --jp-border-color1: var(--color-scale-gray-7);
        --jp-border-color2: var(--color-scale-gray-8);
        --jp-border-color3: var(--color-scale-gray-9);
        --jp-ui-font-color0: ${colors.text};
        --jp-ui-font-color1: ${fade(colors.text, 87)};
        --jp-ui-font-color2: ${fade(colors.text, 54)};
        --jp-ui-font-color3: ${fade(colors.text, 28)};
        --jp-ui-inverse-font-color0: ${colors.crust};
        --jp-ui-inverse-font-color1: ${fade(colors.crust, 80)};
        --jp-ui-inverse-font-color2: ${fade(colors.crust, 50)};
        --jp-ui-inverse-font-color3: ${fade(colors.crust, 30)};
        --jp-content-font-color0: ${colors.text};
        --jp-content-font-color1: ${colors.text};
        --jp-content-font-color2: ${fade(colors.text, 70)};
        --jp-content-font-color3: ${fade(colors.text, 50)};
        --jp-content-link-color: ${colors.sapphire};
        --jp-layout-color0: ${colors.base} !important;
        --jp-layout-color1: var(--color-scale-gray-9);
        --jp-layout-color2: var(--color-scale-gray-8);
        --jp-layout-color3: var(--color-scale-gray-7);
        --jp-layout-color4: var(--color-scale-gray-6);
        --jp-inverse-layout-color0: var(--color-scale-white);
        --jp-inverse-layout-color1: var(--color-scale-white);
        --jp-inverse-layout-color2: var(--color-scale-gray-2);
        --jp-inverse-layout-color3: var(--color-scale-gray-4);
        --jp-inverse-layout-color4: var(--color-scale-gray-6);
        --jp-brand-color0: var(--color-scale-blue-7);
        --jp-brand-color1: var(--color-scale-blue-5);
        --jp-brand-color2: var(--color-scale-blue-3);
        --jp-brand-color3: var(--color-scale-blue-1);
        --jp-brand-color4: var(--color-scale-blue-0);
        --jp-accent-color0: var(--color-scale-green-7);
        --jp-accent-color1: var(--color-scale-green-5);
        --jp-accent-color2: var(--color-scale-green-3);
        --jp-accent-color3: var(--color-scale-green-1);
        --jp-warn-color0: var(--color-scale-orange-7);
        --jp-warn-color1: var(--color-scale-orange-5);
        --jp-warn-color2: var(--color-scale-orange-3);
        --jp-warn-color3: var(--color-scale-orange-1);
        --jp-error-color0: var(--color-scale-red-7);
        --jp-error-color1: var(--color-scale-red-5);
        --jp-error-color2: var(--color-scale-red-3);
        --jp-error-color3: var(--color-scale-red-1);
        --jp-success-color0: var(--color-scale-green-7);
        --jp-success-color1: var(--color-scale-green-5);
        --jp-success-color2: var(--color-scale-green-3);
        --jp-success-color3: var(--color-scale-green-1);
        --jp-info-color0: var(--color-scale-blue-7);
        --jp-info-color1: var(--color-scale-blue-5);
        --jp-info-color2: var(--color-scale-blue-3);
        --jp-info-color3: var(--color-scale-blue-1);
        --jp-cell-editor-background: ${colors.mantle};
        --jp-cell-editor-border-color: var(--color-scale-gray-7);
        --jp-cell-editor-box-shadow: inset 0 0 2px var(--color-scale-blue-3);
        --jp-cell-prompt-not-active-font-color: ${fade(colors.text, 50)};
        --jp-cell-inprompt-font-color: var(--color-scale-blue-6);
        --jp-cell-outprompt-font-color: var(--color-scale-coral-6);
        --jp-notebook-multiselected-color: ${fade(colors.overlay2, 14)};
        --jp-rendermime-error-background: ${fade(colors.red, 18)};
        --jp-rendermime-table-row-background: var(--color-scale-gray-9);
        --jp-rendermime-table-row-hover-background: ${fade(colors.surface2, 14)};
        --jp-dialog-background: ${fade(colors.crust, 60)};
        --jp-toolbar-box-shadow: 0px 0px 2px 0px ${fade(colors.crust, 80)};
        --jp-input-box-shadow: inset 0 0 2px var(--color-scale-blue-3);
        --jp-input-background: var(--color-scale-gray-8);
        --jp-input-active-box-shadow-color: ${fade(colors.blue, 30)};
        --jp-editor-selected-focused-background: ${fade(colors.blue, 14)};
        --jp-mirror-editor-keyword-color: var(--color-scale-green-5);
        --jp-mirror-editor-atom-color: var(--color-scale-blue-3);
        --jp-mirror-editor-number-color: var(--color-scale-green-4);
        --jp-mirror-editor-def-color: var(--color-scale-blue-6);
        --jp-mirror-editor-variable-color: var(--color-scale-gray-3);
        --jp-mirror-editor-variable-2-color: var(--color-scale-blue-4);
        --jp-mirror-editor-variable-3-color: var(--color-scale-green-6);
        --jp-mirror-editor-punctuation-color: var(--color-scale-blue-4);
        --jp-mirror-editor-property-color: var(--color-scale-blue-4);
        --jp-mirror-editor-operator-color: ${colors.mauve};
        --jp-mirror-editor-comment-color: ${colors.subtext0};
        --jp-mirror-editor-string-color: ${colors.peach};
        --jp-mirror-editor-string-2-color: var(--color-scale-purple-3);
        --jp-mirror-editor-meta-color: ${colors.mauve};
        --jp-mirror-editor-qualifier-color: var(--color-scale-gray-5);
        --jp-mirror-editor-builtin-color: var(--color-scale-green-6);
        --jp-mirror-editor-bracket-color: var(--color-scale-gray-2);
        --jp-mirror-editor-tag-color: var(--color-scale-blue-7);
        --jp-mirror-editor-attribute-color: var(--color-scale-blue-7);
        --jp-mirror-editor-header-color: var(--color-scale-blue-5);
        --jp-mirror-editor-quote-color: var(--color-scale-green-3);
        --jp-mirror-editor-link-color: var(--color-scale-blue-7);
        --jp-mirror-editor-error-color: ${colors.red};
        --jp-mirror-editor-hr-color: var(--color-scale-gray-8);
        --jp-vega-background: var(--color-scale-gray-4);
        --jp-search-selected-match-background-color: ${colors.yellow};
        --jp-search-selected-match-color: ${colors.crust};
        --jp-icon-contrast-color0: var(--color-scale-purple-6);
        --jp-icon-contrast-color1: var(--color-scale-green-6);
        --jp-icon-contrast-color2: var(--color-scale-pink-6);
        --jp-icon-contrast-color3: var(--color-scale-blue-6);
    }
`;

    // 应用样式
    GM_addStyle(css);
})();